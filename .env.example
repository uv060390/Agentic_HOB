# ─── BrandOS Environment Variables ────────────────────────────────────────────
# Copy this file to .env and fill in values for local development.
# In production, only INFISICAL_TOKEN, INFISICAL_HOST, BRANDOS_DB_URL,
# BRANDOS_ENV, and LOG_LEVEL are set as system env vars. All other secrets
# come from Infisical at runtime.
# ──────────────────────────────────────────────────────────────────────────────

# ── Core ─────────────────────────────────────────────────────────────────────
BRANDOS_ENV=development
LOG_LEVEL=DEBUG

# ── Database ──────────────────────────────────────────────────────────────────
BRANDOS_DB_URL=postgresql+psycopg://brandos:brandos_dev@localhost:5432/brandos
BRANDOS_SUPABASE_URL=https://<project>.supabase.co
BRANDOS_SUPABASE_KEY=<supabase-service-role-key>

# ── Secret Vault ──────────────────────────────────────────────────────────────
INFISICAL_TOKEN=<machine-identity-token>
INFISICAL_HOST=http://localhost:8080

# ── LLM Providers (local dev only — use Infisical in production) ──────────────
ANTHROPIC_API_KEY=<anthropic-api-key>
CEREBRAS_API_KEY=<cerebras-api-key>

# ── LLM-as-Tool (stored in Infisical, scoped per brand in production) ─────────
OPENAI_API_KEY=<openai-api-key>
PERPLEXITY_API_KEY=<perplexity-api-key>

# ── Messaging ─────────────────────────────────────────────────────────────────
WHATSAPP_VERIFY_TOKEN=<whatsapp-webhook-verify-token>
WHATSAPP_API_TOKEN=<whatsapp-business-api-token>
TELEGRAM_BOT_TOKEN=<telegram-bot-token>

# ── Gateway ───────────────────────────────────────────────────────────────────
GATEWAY_API_KEY=<api-key-for-openclaw-to-gateway>
